# OpenClaw Workspace .gitignore

# 敏感信息
.env
*.meta.json
*secret*
*credential*
stable_access_token.txt

# 日志文件
*.log
logs/

# 临时文件
*.tmp
*.temp
.tmp/
.temp/
temp/

# 媒体文件（钉钉 inbound）
media/inbound/

# 测试文件
test-*.txt
test-*.png
test-*.html
generate-test-image.py

# Skills 子模块（避免嵌入仓库警告）
skills/*/

# 系统文件
.DS_Store
Thumbs.db

# 编辑器
.vscode/
.idea/
*.swp
*.swo
*~

# Node.js
node_modules/

# Python
__pycache__/
*.pyc
.venv/
venv/

# 备份目录外的临时备份
*.tgz
!backups/*.tgz

# 大型媒体文件（可选）
# *.mp4
# *.mov
# *.mp3

